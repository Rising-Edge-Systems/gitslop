{
  "name": "gitslop",
  "version": "1.1.1",
  "description": "A free, open-source, cross-platform GUI git client",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "preview": "electron-vite preview",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "generate-icons": "node scripts/generate-icons.js",
    "gui-test": "python3 scripts/gui-tests/run.py"
  },
  "keywords": [
    "git",
    "electron",
    "react",
    "typescript"
  ],
  "author": {
    "name": "Adam Kidwell",
    "email": "ben.kidwell@gmail.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/Rising-Edge-Systems/gitslop",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rising-Edge-Systems/gitslop.git"
  },
  "build": {
    "appId": "com.gitslop.app",
    "productName": "GitSlop",
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "package.json",
      "resources/icon.png"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "extraMetadata": {
      "main": "./out/main/index.js"
    },
    "publish": {
      "provider": "github",
      "owner": "Rising-Edge-Systems",
      "repo": "gitslop"
    },
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development",
      "icon": "resources/icon.png",
      "synopsis": "A free, open-source, cross-platform GUI git client",
      "description": "GitSlop is a visual git client with branch graphs, inline diffs, built-in editor, and toggleable CLI terminal."
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "icon": "resources/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "identity": null
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "msi",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "chokidar": "^5.0.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.577.0",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^4.7.3",
    "react-window": "^2.2.7"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "electron-vite": "^4.0.1",
    "happy-dom": "^20.8.4",
    "jsdom": "^29.0.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vitest": "^4.1.0"
  }
}
